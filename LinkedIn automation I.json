    {
      "parameters": {
        "jsCode": "function normalize(value) {\n  return String(value ?? \"\")\n    .trim()\n    .toLowerCase()\n    .replace(/\\s+/g, \" \");\n}\n\n// New scraped companies from the earlier JS node\nconst newCompanies = $items(\"Code to structure the company information\");\n\n// Existing rows already present in the Google Sheet\nconst existingRows = $items(\"Get the current rows in the sheet\");\n\n// Build a set of existing keys from the sheet\nconst existingKeys = new Set(\n  existingRows.map(item => {\n    const row = item.json;\n    return `${normalize(row.name)}|||${normalize(row.description)}`;\n  })\n);\n\n// Also dedupe within the current incoming batch\nconst seenNewKeys = new Set();\n\nconst rowsToAppend = [];\n\nfor (const item of newCompanies) {\n  const company = item.json;\n  const key = `${normalize(company.name)}|||${normalize(company.description)}`;\n\n  // Skip if already in sheet\n  if (existingKeys.has(key)) {\n    continue;\n  }\n\n  // Skip if duplicate within this batch\n  if (seenNewKeys.has(key)) {\n    continue;\n  }\n\n  seenNewKeys.add(key);\n\n  rowsToAppend.push({\n    name: company.name ?? \"\",\n    description: company.description ?? \"\",\n    tags: Array.isArray(company.tags) ? company.tags.join(\", \") : (company.tags ?? \"\"),\n    hq: company.hq ?? \"\",\n    linkedin_url: company.linkedin_url ?? \"\",\n    company_website: company.company_website ?? \"\",\n    linkedin_status: company.linkedin_status ?? \"pending\",\n    outreach_status: company.outreach_status ?? \"not_started\",\n    notes: company.notes ?? \"\"\n  });\n}\n\nreturn [\n  {\n    json: {\n      hasUnique: rowsToAppend.length > 0,\n      uniqueCount: rowsToAppend.length,\n      rowsToAppend\n    }\n  }\n];"
      },
